# Ethereum Sepolia L1 RPC URL (Alchemy, Infura, etc.)
# For fastest sync, use a dedicated/paid RPC or run your own Sepolia node
PARENT_CHAIN_RPC_URL=<ethereum-sepolia-rpc>

# Ethereum Sepolia Beacon API URL
PARENT_CHAIN_BEACON_URL=<ethereum-sepolia-beacon>

# Arbitrum chain ID (421614 = Sepolia, 42161 = One)
CHAIN_ID=421614

# Consensus node image
NITRO_IMAGE=offchainlabs/nitro-node:v3.10.0-rc.10-b1cf6db

# Arbitrum Reth image tag (e.g. v0.1.0); defaults to latest
#ARBRETH_TAG=v0.1.0

# Sequencer feed URL (speeds up sync by receiving messages in parallel with L1)
FEED_URL=wss://sepolia-rollup.arbitrum.io/feed

# Consensus node log level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=WARN

# Execution client log level
RUST_LOG=warn

# Data directories (bind mounts; recommended on NVMe). These are the folder
# names the snapshot extracts to. Leave unset to use Docker named volumes.
#DATA_DIR=/data/arbreth-data
#NITRO_DATA_DIR=/data/nitro-data
